{
  "name": "jupyter-tidyblocks-blocks",
  "version": "0.1.0dev",
  "description": "Tidy data analysis blocks for jupyter-tidyblocks.",
  "keywords": [
    "blockly",
    "jupyter",
    "jupyterlab",
    "tidy-data",
    "data-analysis",
    "pandas"
  ],
  "homepage": "https://github.com/teonbrooks/jupyter-tidyblocks",
  "bugs": {
    "url": "https://github.com/teonbrooks/jupyter-tidyblocks/issues"
  },
  "license": "BSD-3-Clause",
  "author": {
    "name": "Teon L. Brooks",
    "email": "teon.brooks@gmail.com"
  },
  "files": [
    "lib/**/*.{cjs,mjs,d.ts,d.ts.map,json}",
    "style/**/*.{css,js,json}"
  ],
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/teonbrooks/jupyter-tidyblocks"
  },
  "scripts": {
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "clean": "rimraf lib tsconfig.tsbuildinfo",
    "clean:all": "rimraf lib tsconfig.tsbuildinfo",
    "install:extension": "jlpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "blockly": "^12.0",
    "jupyter-tidyblocks": "^0.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "jsdom": "^25.0.0",
    "rimraf": "^6.0.0",
    "typescript": "~5.7",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
