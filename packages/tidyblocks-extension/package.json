{
  "name": "jupyter-tidyblocks-extension",
  "version": "0.1.0-alpha.0",
  "description": "Tidy data analysis extension for jupyter-blocks.",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "blockly",
    "tidy-data",
    "data-analysis"
  ],
  "homepage": "https://github.com/teonbrooks/jupyter-blocks",
  "bugs": {
    "url": "https://github.com/teonbrooks/jupyter-blocks/issues"
  },
  "license": "BSD-3-Clause",
  "author": {
    "name": "Teon L. Brooks",
    "email": "teon.brooks@gmail.com"
  },
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "style/**/*.{css,js,eot,gif,html,jpg,json,png,svg,woff2,ttf}"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/teonbrooks/jupyter-blocks"
  },
  "scripts": {
    "build": "npm run build:lib && npm run build:labextension:dev",
    "build:prod": "npm run clean && npm run build:lib && npm run build:labextension",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "build:lib": "tsc",
    "clean": "npm run clean:lib",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "clean:labextension": "rimraf ../../jupyter_tidyblocks/labextension",
    "clean:all": "npm run clean:lib && npm run clean:labextension",
    "install:extension": "npm run build",
    "watch": "run-p watch:src watch:labextension",
    "watch:src": "tsc -w --sourceMap",
    "watch:labextension": "jupyter labextension watch ."
  },
  "dependencies": {
    "@jupyterlab/application": "^4.5",
    "jupyter-blocks": "^0.1.0-alpha.0",
    "jupyter-tidyblocks": "^0.1.0-alpha.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.5",
    "npm-run-all2": "^7.0.0",
    "rimraf": "^6.0.0",
    "typescript": "~5.7"
  },
  "sideEffects": [
    "style/*.css",
    "style/index.js"
  ],
  "styleModule": "style/index.js",
  "publishConfig": {
    "access": "public"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "../../jupyter_tidyblocks/labextension",
    "sharedPackages": {
      "jupyter-blocks": {
        "bundled": false,
        "singleton": true
      },
      "jupyter-tidyblocks": {
        "bundled": true,
        "singleton": true
      },
      "blockly": {
        "bundled": false,
        "singleton": true
      }
    }
  }
}
