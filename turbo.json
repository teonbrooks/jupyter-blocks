{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["lib/**", "../../jupyter_tidyblocks/labextension/**"]
    },
    "build:prod": {
      "dependsOn": ["^build:prod"],
      "outputs": ["lib/**", "../../jupyter_tidyblocks/labextension/**"]
    },
    "clean": {
      "cache": false
    },
    "clean:all": {
      "cache": false
    },
    "install:extension": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "watch": {
      "cache": false,
      "persistent": true
    }
  }
}
